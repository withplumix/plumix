{
  "name": "@plumix-examples/minimal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Smallest buildable Plumix app — Cloudflare + D1",
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .plumix .wrangler dist node_modules",
    "dev": "plumix dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plumix/core": "workspace:*",
    "@plumix/runtime-cloudflare": "workspace:*",
    "plumix": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
