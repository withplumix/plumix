{
  "name": "@plumix-examples/blog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Plumix app with the blog and pages plugins — Cloudflare + D1",
  "license": "MIT",
  "scripts": {
    "build": "plumix migrate generate && plumix build",
    "clean": "git clean -xdf .plumix .wrangler dist drizzle node_modules",
    "dev": "plumix migrate generate && plumix dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plumix/blocks": "workspace:*",
    "@plumix/plugin-blog": "workspace:*",
    "@plumix/plugin-comments": "workspace:*",
    "@plumix/plugin-media": "workspace:*",
    "@plumix/plugin-menu": "workspace:*",
    "@plumix/plugin-pages": "workspace:*",
    "@plumix/runtime-cloudflare": "workspace:*",
    "plumix": "workspace:*",
    "react": "catalog:react"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@plumix/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:tailwind",
    "@tailwindcss/typography": "catalog:tailwind",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "tailwindcss": "catalog:tailwind",
    "typescript": "catalog:",
    "wrangler": "catalog:cloudflare"
  }
}
