{
  "name": "@plumix/plugin-media",
  "version": "0.1.0",
  "type": "module",
  "description": "Media plugin for Plumix — uploads, library, and CDN delivery",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/plugins/media"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "plumix",
    "plugin",
    "media",
    "uploads"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fields": {
      "types": "./dist/fields.d.ts",
      "default": "./dist/fields.js"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "default": "./dist/blocks.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "i18n:extract": "lingui extract",
    "i18n:compile": "plumix-compile-catalogs",
    "i18n:check": "plumix i18n verify",
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules e2e/playwright-report e2e/test-results",
    "format": "prettier --check . --ignore-path ../../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "publint": "publint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "valibot": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-query": "catalog:tanstack",
    "plumix": "workspace:>=0.1.0 <1.0.0",
    "react": "catalog:react"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@lingui/cli": "catalog:lingui",
    "@playwright/test": "catalog:",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/lingui-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/runtime-cloudflare": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@tanstack/react-query": "catalog:tanstack",
    "@testing-library/jest-dom": "catalog:testing-library",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitest/coverage-v8": "catalog:vitest",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "plumix": "workspace:*",
    "prettier": "catalog:",
    "publint": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  },
  "prettier": "@plumix/prettier-config",
  "plumix": {
    "scaffold": {
      "kind": "plugin",
      "id": "media",
      "label": "Media",
      "description": "Uploads, library, and CDN delivery",
      "category": "content",
      "registration": "media()",
      "imports": [
        "import { media } from \"@plumix/plugin-media\";"
      ],
      "requires": [
        "storage",
        "imageDelivery"
      ]
    }
  }
}
