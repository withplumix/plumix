{
  "name": "@plumix/plugin-blog",
  "version": "0.1.0",
  "type": "module",
  "description": "Blog plugin for Plumix — posts, categories, tags",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/plugins/blog"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "plumix",
    "plugin",
    "blog",
    "posts"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "i18n:extract": "lingui extract",
    "i18n:compile": "plumix-compile-catalogs",
    "i18n:check": "plumix i18n verify",
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "publint": "publint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "drizzle-orm": "catalog:drizzle"
  },
  "peerDependencies": {
    "plumix": "workspace:>=0.1.0 <1.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@lingui/cli": "catalog:lingui",
    "@playwright/test": "catalog:",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/lingui-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/runtime-cloudflare": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:vitest",
    "eslint": "catalog:",
    "plumix": "workspace:*",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  },
  "prettier": "@plumix/prettier-config",
  "plumix": {
    "scaffold": {
      "kind": "plugin",
      "id": "blog",
      "label": "Blog",
      "description": "Posts, categories, and tags",
      "category": "content",
      "registration": "blog",
      "imports": [
        "import { blog } from \"@plumix/plugin-blog\";"
      ]
    }
  }
}
