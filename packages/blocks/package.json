{
  "name": "@plumix/blocks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "default": "./dist/renderer/index.js"
    },
    "./island-runtime": {
      "types": "./dist/island-runtime.d.ts",
      "default": "./dist/island-runtime.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@tiptap/core": "^3.23.5",
    "sanitize-html": "^2.17.4"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "jsdom": "^29.1.1",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
