    "./admin/ui": {
      "types": "./dist/admin/ui.d.ts",
      "default": "./dist/admin/ui.js"
    },
    "./test/playwright": {
      "types": "./dist/test/playwright.d.ts",
      "default": "./dist/test/playwright.js"
