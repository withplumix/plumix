{
  "name": "plumix",
  "version": "0.0.0",
  "type": "module",
  "description": "A headless CMS for the edge, built on Cloudflare Workers",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/withplumix/plumix.git",
    "directory": "packages/plumix"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": ["cms", "cloudflare-workers", "edge", "typescript", "headless-cms"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    }
  },
  "bin": {
    "plumix": "./dist/cli/index.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "attw": "attw --pack .",
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "publint": "publint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@plumix/core": "workspace:*"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
