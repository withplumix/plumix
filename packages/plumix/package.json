{
  "name": "plumix",
  "version": "0.0.0",
  "type": "module",
  "description": "A headless CMS for the edge, built on Cloudflare Workers",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/plumix"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "cms",
    "cloudflare-workers",
    "edge",
    "typescript",
    "headless-cms"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "default": "./dist/theme/index.js"
    },
    "./vite": {
      "types": "./dist/vite/index.d.ts",
      "default": "./dist/vite/index.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "default": "./dist/admin/index.js"
    },
    "./admin/react": {
      "types": "./dist/admin/react.d.ts",
      "default": "./dist/admin/react.js"
    },
    "./admin/react-jsx-runtime": {
      "types": "./dist/admin/react-jsx-runtime.d.ts",
      "default": "./dist/admin/react-jsx-runtime.js"
    },
    "./admin/react-dom": {
      "types": "./dist/admin/react-dom.d.ts",
      "default": "./dist/admin/react-dom.js"
    },
    "./admin/react-dom-client": {
      "types": "./dist/admin/react-dom-client.d.ts",
      "default": "./dist/admin/react-dom-client.js"
    },
    "./admin/react-query": {
      "types": "./dist/admin/react-query.d.ts",
      "default": "./dist/admin/react-query.js"
    },
    "./admin/react-router": {
      "types": "./dist/admin/react-router.d.ts",
      "default": "./dist/admin/react-router.js"
    },
    "./admin/orpc-client": {
      "types": "./dist/admin/orpc-client.d.ts",
      "default": "./dist/admin/orpc-client.js"
    },
    "./admin/orpc-client-fetch": {
      "types": "./dist/admin/orpc-client-fetch.d.ts",
      "default": "./dist/admin/orpc-client-fetch.js"
    },
    "./admin/orpc-tanstack-query": {
      "types": "./dist/admin/orpc-tanstack-query.d.ts",
      "default": "./dist/admin/orpc-tanstack-query.js"
    },
    "./test/playwright": {
      "types": "./dist/test/playwright.d.ts",
      "default": "./dist/test/playwright.js"
    },
    "./blocks": {
      "types": "./dist/blocks/index.d.ts",
      "default": "./dist/blocks/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./fields": {
      "types": "./dist/fields/index.d.ts",
      "default": "./dist/fields/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "default": "./dist/i18n/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    }
  },
  "bin": {
    "plumix": "./bin/plumix.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-admin.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "publint": "publint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@plumix/core": "workspace:*",
    "@tailwindcss/node": "4.2.4",
    "@tailwindcss/oxide": "4.2.4",
    "drizzle-kit": "catalog:",
    "esbuild": "0.27.7",
    "jiti": "^2.6.1",
    "tailwindcss": "4.2.4",
    "valibot": "catalog:"
  },
  "peerDependencies": {
    "@orpc/client": "^1.13.0",
    "@orpc/tanstack-query": "^1.13.0",
    "@playwright/test": "^1.59.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.0",
    "drizzle-orm": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:"
  },
  "peerDependenciesMeta": {
    "@orpc/client": {
      "optional": true
    },
    "@orpc/tanstack-query": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@orpc/client": "^1.14.0",
    "@orpc/tanstack-query": "^1.14.0",
    "@playwright/test": "^1.59.1",
    "@plumix/admin": "workspace:*",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.25",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
