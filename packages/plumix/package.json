    "./blocks": {
      "types": "./dist/blocks/index.d.ts",
      "default": "./dist/blocks/index.js"
    },
    "./blocks/renderer": {
      "types": "./dist/blocks/renderer.d.ts",
      "default": "./dist/blocks/renderer.js"
    },
    "./blocks/test": {
      "types": "./dist/blocks/test.d.ts",
      "default": "./dist/blocks/test.js"
    },
    "./blocks/island-runtime": {
      "types": "./dist/blocks/island-runtime.d.ts",
      "default": "./dist/blocks/island-runtime.js"
    },
    "./blocks/island-renderer": {
      "types": "./dist/blocks/island-renderer.d.ts",
      "default": "./dist/blocks/island-renderer.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./db/libsql": {
      "types": "./dist/db/libsql.d.ts",
      "default": "./dist/db/libsql.js"
    },
    "./fields": {
      "types": "./dist/fields/index.d.ts",
      "default": "./dist/fields/index.js"
    },
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "default": "./dist/i18n/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    },
    "./editor-runtime": {
      "types": "./dist/editor-runtime.d.ts",
      "default": "./dist/editor-runtime.js"
    }
  },
  "bin": {
    "plumix": "./bin/plumix.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-admin.mjs",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "publint": "publint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@lingui/core": "catalog:lingui",
    "@lingui/react": "catalog:lingui",
    "@plumix/admin-editor": "workspace:*",
    "@plumix/admin-ui": "workspace:*",
    "@plumix/blocks": "workspace:*",
    "@plumix/core": "workspace:*",
    "@tailwindcss/node": "catalog:tailwind",
    "@tailwindcss/oxide": "catalog:tailwind",
    "drizzle-kit": "catalog:drizzle",
    "esbuild": "catalog:",
    "jiti": "^2.6.1",
    "tailwindcss": "catalog:tailwind",
    "valibot": "catalog:"
  },
  "peerDependencies": {
    "@orpc/client": "catalog:orpc",
    "@orpc/tanstack-query": "catalog:orpc",
    "@playwright/test": "catalog:",
    "@tanstack/react-query": "catalog:tanstack",
    "@tanstack/react-router": "catalog:tanstack",
    "drizzle-orm": "catalog:drizzle",
    "radix-ui": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "vite": "catalog:vite"
  },
