{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // tsconfig.json widens rootDir to `.` so eslint can type-aware lint the
    // e2e/ tree. The build must constrain back to src/ — otherwise dist/
    // inherits the wider rootDir and emits under `dist/src/`, breaking the
    // package.json exports entry.
    "rootDir": "src",
    "stripInternal": true,
    "tsBuildInfoFile": "${configDir}/.cache/build.tsbuildinfo"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
