{
  "name": "@plumix/runtime-cloudflare",
  "version": "0.0.0",
  "type": "module",
  "description": "Cloudflare Workers runtime adapter for Plumix",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/runtimes/cloudflare"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "plumix",
    "cloudflare-workers",
    "runtime",
    "d1",
    "r2"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "default": "./dist/commands/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../../.gitignore",
    "lint": "eslint",
    "publint": "publint",
    "test": "vitest run",
    "test:unit": "vitest run src --passWithNoTests",
    "test:integration": "vitest run test --passWithNoTests",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@plumix/core": "workspace:*",
    "jsonc-parser": "^3.3.1",
    "plumix": "workspace:*",
    "smol-toml": "^1.6.1",
    "vite": "catalog:"
  },
  "peerDependencies": {
    "drizzle-orm": "catalog:",
    "wrangler": "^4"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^4.36.0"
  },
  "prettier": "@plumix/prettier-config"
}
