{
  "name": "@plumix/runtime-cloudflare",
  "version": "0.3.1",
  "type": "module",
  "description": "Cloudflare Workers runtime adapter for Plumix",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/runtimes/cloudflare"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "plumix",
    "cloudflare-workers",
    "runtime",
    "d1",
    "r2"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./commands": {
      "types": "./dist/commands/index.d.ts",
      "default": "./dist/commands/index.js"
    },
    "./demo": {
      "types": "./dist/demo/index.d.ts",
      "default": "./dist/demo/index.js"
    },
    "./demo/durable-object": {
      "types": "./dist/demo/durable-object.d.ts",
      "default": "./dist/demo/durable-object.js"
    }
  },
  "files": [
    "dist",
    "scaffold",
    "README.md",
    "LICENSE"
  ],
  "plumix": {
    "scaffold": {
      "kind": "runtime",
      "id": "cloudflare",
      "label": "Cloudflare",
      "description": "Cloudflare Workers + D1",
      "imports": [
        "import { cloudflare, cloudflareDeployOrigin, d1 } from \"@plumix/runtime-cloudflare\";"
      ],
      "configSlots": {
        "runtime": "cloudflare()",
        "database": "d1({ binding: \"DB\", session: \"auto\" })"
      },
      "authOrigin": "...cloudflareDeployOrigin({ workerName: \"__PROJECT_NAME__\", accountSubdomain: \"your-account\", localOrigin: \"http://localhost:5173\" })",
      "authOriginComment": "Set accountSubdomain to your workers.dev subdomain before deploying.",
      "deps": {
        "@plumix/runtime-cloudflare": "workspace:*"
      },
      "devDeps": {
        "@cloudflare/workers-types": "catalog:cloudflare",
        "wrangler": "catalog:cloudflare"
      },
      "files": {
        "wrangler.jsonc": "scaffold/wrangler.jsonc"
      },
      "capabilities": {
        "storage": {
          "imports": [
            "import { r2 } from \"@plumix/runtime-cloudflare\";"
          ],
          "configSlots": {
            "storage": "r2({ binding: \"MEDIA\" })"
          },
          "wrangler": {
            "r2_buckets": [
              {
                "binding": "MEDIA",
                "bucket_name": "__PROJECT_NAME__-media"
              }
            ]
          }
        },
        "imageDelivery": {
          "imports": [
            "import { images } from \"@plumix/runtime-cloudflare\";"
          ],
          "configSlots": {
            "imageDelivery": "images()"
          }
        }
      },
      "authMethods": {
        "cfAccess": {
          "label": "Cloudflare Access (SSO)",
          "description": "Gate the app behind your Cloudflare Access IdP",
          "comment": "Create a Cloudflare Access application and set teamDomain + its audience (AUD) tag.",
          "imports": [
            "import { cfAccess } from \"@plumix/runtime-cloudflare\";"
          ],
          "authEntry": "authenticator: cfAccess({ teamDomain: \"your-team.cloudflareaccess.com\", audience: \"your-cf-access-aud\", defaultRole: \"editor\" })"
        }
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "attw": "attw --pack . --profile esm-only",
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../../.gitignore",
    "lint": "eslint",
    "publint": "publint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "catalog:cloudflare",
    "jose": "^6.2.3",
    "jsonc-parser": "catalog:",
    "smol-toml": "^1.7.0",
    "vite": "catalog:vite"
  },
  "peerDependencies": {
    "drizzle-orm": "catalog:drizzle",
    "plumix": "workspace:^",
    "wrangler": "catalog:cloudflare"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@cloudflare/workers-types": "catalog:cloudflare",
    "@libsql/client": "catalog:",
    "@playwright/test": "catalog:",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:vitest",
    "eslint": "catalog:",
    "plumix": "workspace:*",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest",
    "wrangler": "catalog:cloudflare"
  },
  "prettier": "@plumix/prettier-config"
}
