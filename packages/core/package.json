{
  "name": "@plumix/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/config.d.ts",
      "default": "./dist/auth/config.js"
    },
    "./schema": {
      "types": "./dist/db/schema/index.d.ts",
      "default": "./dist/db/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .drizzle .turbo dist node_modules",
    "db:generate": "drizzle-kit generate",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run src --passWithNoTests",
    "test:integration": "vitest run test --passWithNoTests",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@orpc/server": "^1.13.14",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/webauthn": "^1.0.0",
    "drizzle-orm": "catalog:",
    "drizzle-valibot": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "fishery": "^2.4.0",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
