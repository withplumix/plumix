{
  "name": "@plumix/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth/config.d.ts",
      "default": "./dist/auth/config.js"
    },
    "./schema": {
      "types": "./dist/db/schema/index.d.ts",
      "default": "./dist/db/schema/index.js"
    },
    "./test": {
      "types": "./dist/test/index.d.ts",
      "default": "./dist/test/index.js"
    },
    "./test/playwright": {
      "types": "./dist/test/playwright/index.d.ts",
      "default": "./dist/test/playwright/index.js"
    },
    "./validation": {
      "types": "./dist/rpc/validation.d.ts",
      "default": "./dist/rpc/validation.js"
    },
    "./manifest": {
      "types": "./dist/plugin/manifest.d.ts",
      "default": "./dist/plugin/manifest.js"
    },
    "./fields": {
      "types": "./dist/plugin/fields/index.d.ts",
      "default": "./dist/plugin/fields/index.js"
    },
    "./slugify": {
      "types": "./dist/slugify.d.ts",
      "default": "./dist/slugify.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .drizzle .turbo dist node_modules",
    "db:generate": "drizzle-kit generate",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@orpc/server": "^1.14.1",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/webauthn": "^1.0.0",
    "@sindresorhus/slugify": "^3.0.0",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "drizzle-valibot": "catalog:",
    "fishery": "^2.4.0",
    "valibot": "catalog:"
  },
  "peerDependencies": {
    "@playwright/test": "^1.59.0",
    "esbuild": "^0.27.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild": "0.27.7",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
