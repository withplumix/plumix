{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "stripInternal": true,
    // tsconfig.json widens rootDir to the package root for the playground;
    // the dist build is src-only, so pin it back and re-enable emit (the wide
    // config sets noEmit to stay typecheck-only).
    "rootDir": "src",
    "noEmit": false,
    "tsBuildInfoFile": "${configDir}/.cache/build.tsbuildinfo"
  },
  // The published library is src-only; the playground + e2e + tool configs
  // that tsconfig.json adds for typecheck/eslint must stay out of dist.
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
