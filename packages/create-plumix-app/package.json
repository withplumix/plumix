{
  "name": "create-plumix-app",
  "version": "0.1.2",
  "type": "module",
  "description": "Scaffold a new Plumix project",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/create-plumix-app"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "create",
    "scaffold",
    "plumix",
    "cms"
  ],
  "bin": {
    "create-plumix-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "base",
    "registry.json",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "jsonc-parser": "catalog:"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && plumix-assert-emit",
    "clean": "git clean -xdf .cache .turbo dist node_modules templates",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "prepack": "tsc -p tsconfig.build.json && node scripts/sync-template.mjs && node scripts/build-snapshot.mjs",
    "publint": "publint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:vitest",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  },
  "prettier": "@plumix/prettier-config"
}
