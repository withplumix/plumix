{
  "name": "@plumix/admin",
  "version": "0.1.3",
  "type": "module",
  "description": "Plumix admin application (prebuilt SPA assets)",
  "license": "MIT",
  "author": "Plumix Contributors",
  "homepage": "https://github.com/withplumix/plumix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/withplumix/plumix.git",
    "directory": "packages/admin"
  },
  "bugs": {
    "url": "https://github.com/withplumix/plumix/issues"
  },
  "keywords": [
    "plumix",
    "cms",
    "admin"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules playwright-report test-results",
    "dev": "vite",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "i18n:check": "node ../plumix/bin/plumix.mjs i18n extract --check",
    "i18n:compile": "plumix-compile-catalogs",
    "i18n:extract": "lingui extract",
    "i18n:ratchet:check": "node scripts/ratchet-drift-check.mjs",
    "lint": "eslint",
    "publint": "publint",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^8.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@lingui/babel-plugin-lingui-macro": "catalog:lingui",
    "@lingui/cli": "catalog:lingui",
    "@lingui/core": "catalog:lingui",
    "@lingui/react": "catalog:lingui",
    "@lingui/vite-plugin": "catalog:lingui",
    "@orpc/client": "catalog:orpc",
    "@orpc/tanstack-query": "catalog:orpc",
    "@playwright/test": "catalog:",
    "@plumix/admin-editor": "workspace:*",
    "@plumix/admin-ui": "workspace:*",
    "@plumix/blocks": "workspace:*",
    "@plumix/core": "workspace:*",
    "@plumix/eslint-config": "workspace:*",
    "@plumix/lingui-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "@plumix/typescript-config": "workspace:*",
    "@plumix/vitest-config": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.0",
    "@tailwindcss/vite": "catalog:tailwind",
    "@tanstack/react-query": "catalog:tanstack",
    "@tanstack/react-query-devtools": "catalog:tanstack",
    "@tanstack/react-router": "catalog:tanstack",
    "@tanstack/react-router-devtools": "catalog:tanstack",
    "@tanstack/react-table": "catalog:tanstack",
    "@tanstack/router-plugin": "catalog:tanstack",
    "@testing-library/jest-dom": "catalog:testing-library",
    "@testing-library/react": "catalog:testing-library",
    "@testing-library/user-event": "catalog:testing-library",
    "@tiptap/core": "catalog:tiptap",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@vitejs/plugin-react": "catalog:vite",
    "@vitest/coverage-v8": "catalog:vitest",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "publint": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-hook-form": "catalog:",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:tailwind",
    "tsx": "4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "ua-parser-js": "^2.0.10",
    "valibot": "catalog:",
    "vite": "catalog:vite",
    "vitest": "catalog:vitest"
  },
  "prettier": "@plumix/prettier-config"
}
