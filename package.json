{
  "name": "root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24.15.0",
    "pnpm": "^10.33.0"
  },
  "scripts": {
    "attw": "turbo run attw",
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "commitlint": "commitlint",
    "dev": "turbo watch dev --continue",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "i18n:check": "turbo run i18n:check",
    "i18n:ratchet:check": "turbo run i18n:ratchet:check",
    "knip": "knip",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "postinstall": "pnpm dlx sherif@latest",
    "publint": "turbo run publint",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/config-pnpm-scopes": "^21.0.2",
    "@commitlint/types": "^21.1.0",
    "@types/node": "catalog:",
    "knip": "^6.18.0",
    "turbo": "^2.9.18"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/pm": "3.23.4",
      "esbuild@<0.25.0": ">=0.25.0",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8",
      "js-yaml@>=4.0.0 <4.2.0": ">=4.2.0 <5"
    }
  }
}
