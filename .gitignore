# cloudflare
.wrangler/

# drizzle-kit generated migrations (committed under packages once a release flow is in place)
.drizzle/
.output/
# `plumix migrate generate` output in playgrounds + examples — generated
# fresh on every e2e run, never committed. The blog example is the
# exception: its migrations are committed so the demo sandbox can apply
# them to a fresh per-session Durable Object at runtime (see #1338).
drizzle/
!/examples/blog/drizzle/
!/packages/runtimes/cloudflare/e2e/fixture/drizzle/

# worker-driven plugin e2e: storageState.json + e2e-fixtures.json are
# written by globalSetup at the package root; playwright traces / reports
# land in test-results/ + playwright-report/ (already covered above).
storageState.json
e2e-fixtures.json

# plumix generated
.plumix/

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Internal planning and reference docs (not committed)
PLAN.md
.claude/

# Compiled lingui catalogs — generated by `plumix-compile-catalogs`,
# never committed. Source of truth is the sibling `.po` files.
packages/*/locales/*.mjs
packages/*/locales/*.d.mts
packages/plugins/*/locales/*.mjs
packages/plugins/*/locales/*.d.mts

# Cloudflare local secrets
.dev.vars
.dev.vars.*
