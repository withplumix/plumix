{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "plumix-marketing",
  "main": ".plumix/worker.ts",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  // Marketing is the apex site. Production is served only on the custom domain
  // (no *.workers.dev), but keep per-version preview URLs on workers.dev for
  // branch deploys. Declaring the route keeps deploys reconciled with the domain
  // attached in the dashboard.
  "workers_dev": false,
  "preview_urls": true,
  "routes": [{ "pattern": "plumix.dev", "custom_domain": true }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "plumix_marketing",
      "database_id": "b68893f4-b79a-454e-8d5e-0dfcb6e1ef7d",
      "migrations_dir": "drizzle",
    },
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "plumix-marketing",
    },
  ],
  "assets": {
    "directory": ".plumix/public",
    "binding": "ASSETS",
    "not_found_handling": "none",
  },
  // Fires plumix's scheduled tasks. `0 3 * * *` matches the core
  // session-cleanup task (daily); `*/5 * * * *` matches publish-scheduled
  // (publishes due future-dated entries within 5 minutes).
  "triggers": {
    "crons": ["0 3 * * *", "*/5 * * * *"],
  },
}
