{
  "name": "@plumix-apps/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Plumix documentation site — Astro Starlight (scaffold; content + versioning land with the docs follow-up)",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "clean": "git clean -xdf .astro dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .gitignore",
    "lint": "astro sync && eslint",
    "typecheck": "astro sync && tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@plumix/eslint-config": "workspace:*",
    "@plumix/prettier-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@plumix/prettier-config"
}
